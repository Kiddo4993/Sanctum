# ============================================================
# Sanctum Environment Variables
#
# Copy this file to `.env` and fill in your actual API keys.
# NEVER commit the real `.env` file to version control.
# ============================================================

# ── 1. Client-Side Variables (Visible in App) ────────────────

# Supabase (React Native Client)
EXPO_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Firebase (Firestore for Groups/DMs)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# External APIs (Client usage fallback)
EXPO_PUBLIC_BIBLE_API_KEY=your_bible_api_key


# ── 2. Backend-Only Variables (Supabase Edge Functions) ──────
# These should NOT be exported to React Native (no EXPO_PUBLIC_ prefix).
# They are set directly in the Supabase Dashboard > Edge Functions.

OPENAI_API_KEY=sk-your_openai_api_key
ELEVENLABS_API_KEY=sk-your_elevenlabs_api_key
MAILCHIMP_API_KEY=your_mailchimp_key-us21
MAILCHIMP_LIST_ID=your_audience_id

# Supabase Root Service Key (Needed inside Edge Functions to bypass RLS)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
